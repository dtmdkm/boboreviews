{
  "redirects": [
    {
      "source": "/store.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>.*)"
        }
      ],
      "destination": "/store/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/store/:slug",
      "destination": "/store-page.html?slug=:slug"
    },
    {
      "source": "/category/:slug",
      "destination": "/category.html?slug=:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(js|css|png|jpg|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
