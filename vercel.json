{
  "cleanUrls": true,
  "redirects": [
    { "source": "/Store/(.*)", "destination": "/store/$1", "permanent": true },
    { "source": "/Category/(.*)", "destination": "/category/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/store/:slug*", "destination": "/store-page.html?slug=:slug*" },
    { "source": "/category/:slug*", "destination": "/category.html?slug=:slug*" }
  ]
}
