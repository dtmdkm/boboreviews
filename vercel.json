{
  "redirects": [
    { "source": "/store.html?slug=:slug", "destination": "/store/:slug", "permanent": true },
    { "source": "/category.html?slug=:slug", "destination": "/category/:slug", "permanent": true },
    { "source": "/Store/(.*)", "destination": "/store/$1", "permanent": true },
    { "source": "/Category/(.*)", "destination": "/category/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/store/(.*)", "destination": "/store-page.html?slug=$1" },
    { "source": "/category/(.*)", "destination": "/category.html?slug=$1" }
  ]
}
