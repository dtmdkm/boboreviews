{
  "redirects": [
    {
      "source": "/store.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>.*)"
        }
      ],
      "destination": "/store/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/store/:slug",
      "destination": "/store.html?slug=:slug"
    },
    {
      "source": "/category/:slug",
      "destination": "/index.html?category=:slug"
    }
  ]
}
